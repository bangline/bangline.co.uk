<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv='X-UA-Compatible' content='IE=edge;chrome=1' />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>>_ Bangline <%= ' - ' + current_article.title unless current_article.nil? %></title>
    <link href='https://fonts.googleapis.com/css?family=Quattrocento|Quattrocento+Sans' rel='stylesheet' type='text/css'>
    <%= stylesheet_link_tag 'normalize' %>
    <%= stylesheet_link_tag 'main' %>
  </head>
  <body>
    <header>
      <div class="content">
        <a href="/" title="Bangline.co.uk Home Page" id="logo">
          <%= image_tag  "logo.png", alt: "The Bangline Logo" %>
        </a>
        <nav>
          <ul class="ul-no-style nav nav-inline">
            <li><a href="#">About</a></li>
            <li><a href="#">Github</a></li>
            <li><a href="#">Twitter</a></li>
            <li><a href="#">Sandbox</a></li>
            <li><a href="http://goo.gl/forms/Esh58FcKlJ">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <%= yield %>
    </main>
    <footer>
      <div class="content">
        <nav>
          <ul class="ul-no-style nav nav-inline">
            <li><a href="#">About</a></li>
            <li><a href="#">Github</a></li>
            <li><a href="#">Twitter</a></li>
            <li><a href="#">Sandbox</a></li>
            <li><a href="http://goo.gl/forms/Esh58FcKlJ">Contact</a></li>
          </ul>
        </nav>
      </div>
    </footer>
  </body>
</html>
