<div class="content">
  <h2>Talks</h2>
  <ul class="index-list ul-no-style nav">
    <% data.talks.each do |talk| %>
      <li>
        <%= link_to talk.title, "/talks/#{talk.title.to_slug}.html" %>
      </li>
    <% end %>
  </ul>
  <%# <nav> %>
  <%#   <a href="#" class="button">More</a> %>
  <%# </nav> %>
</div>
<div class="content">
  <h2>Elsewhere</h2>
  <ul class="index-list ul-no-style nav">
    <% data.others.each do |other| %>
      <li>
      <% link_to other.url do %>
        <time class="timestamp"><%= other.date.strftime('%F') %></time>
        <%= other.title %>
      <% end %>
      </li>
    <% end %>
  </ul>
</div>
