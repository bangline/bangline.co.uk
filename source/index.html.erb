  <%#     <a href="#" class="button">More</a> %>
  <%#   </nav> %>
  <%# <% end %1> %>
</div>
<div class="content">
  <h2>Articles</h2>
  <ul class="index-list ul-no-style nav">
    <% blog("articles").articles[0...10].each do |article| %>
      <li>
        <% link_to article do %>
          <%= article.title %>
        <% end %>
      </li>
    <% end %>
  </ul>
  <%# <nav> %>
