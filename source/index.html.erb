<div class="content">
  <h2>Journal</h2>
  <ul class="index-list ul-no-style nav">
    <% blog("journal").articles[0...10].each do |article| %>
      <li>
        <% link_to article do %>
          <time class="timestamp"><%= article.date.strftime('%F') %></time>
          <%= article.title %>
        <% end %>
      </li>
    <% end %>
  </ul>
  <%# <% if blog("journal").articles.count > 10 %1> %>
